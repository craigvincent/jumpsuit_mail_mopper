# Auto detect text files and perform LF normalization
* text=auto

# C# source files
*.cs text diff=csharp

# Common settings
*.json text
*.xml text
*.md text
*.yml text
*.yaml text
*.slnx text

# Windows-specific
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.gif binary
