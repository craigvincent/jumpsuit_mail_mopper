# Auto detect text files and normalise to CRLF (matches .editorconfig)
* text=auto eol=crlf

# C# source files
*.cs text diff=csharp eol=crlf

# Common settings
*.json text eol=crlf
*.xml text eol=crlf
*.md text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.slnx text eol=crlf

# Shell scripts always LF
*.sh text eol=lf

# Windows-specific
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.gif binary
